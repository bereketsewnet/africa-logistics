# ─── Africa Logistics — Frontend ──────────────────────────────────────────────
# Canonical frontend domain
africa-logistics.lula.com.et {
    handle_path /uploads/* {
        root * /srv/uploads
        file_server
    }
    reverse_proxy africa_frontend:80
}

# Legacy alias -> redirect to canonical domain so users always get latest UI.
afri-logistics.lula.com.et {
    redir https://africa-logistics.lula.com.et{uri} 308
}

# ─── Africa Logistics — Backend API ───────────────────────────────────────────
# /uploads/* is served as static files from the shared Docker volume.
# All other paths are proxied to the Fastify backend.
africa-logistics-api.lula.com.et {
    handle_path /uploads/* {
        root * /srv/uploads
        file_server
    }
    handle {
        reverse_proxy africa_backend:3000
    }
}

# Legacy API alias -> redirect to canonical API domain.
afri-logistics-api.lula.com.et {
    redir https://africa-logistics-api.lula.com.et{uri} 308
}

# ─── Bemnet AI Assistant — Frontend ───────────────────────────────────────────
bemnet-ai-assitant.lula.com.et {
    reverse_proxy ai_assistance_frontend:3000
}

# ─── Bemnet AI Assistant — Backend API ────────────────────────────────────────
bemnet-ai-assitant-api.lula.com.et {
    reverse_proxy ai_assistance_backend:8001
}
